@@ -0,0 +1,130 @@
+from __future__ import annotations
+
+from pathlib import Path
+from typing import Dict, Mapping, Optional
+
+import numpy as np
+import pandas as pd
+
+Array = np.ndarray
+
+
+def squared_error_per_sample(y_true: Array, y_pred: Array) -> Array:
+    y_true = np.asarray(y_true, dtype=float).reshape(-1)
+    y_pred = np.asarray(y_pred, dtype=float).reshape(-1)
+    return (y_pred - y_true) ** 2
+
+
+def absolute_error_per_sample(y_true: Array, y_pred: Array) -> Array:
+    y_true = np.asarray(y_true, dtype=float).reshape(-1)
+    y_pred = np.asarray(y_pred, dtype=float).reshape(-1)
+    return np.abs(y_pred - y_true)
+
+
+def compute_regression_metrics(y_true: Array, y_pred: Array) -> Dict[str, float]:
+    y_true = np.asarray(y_true, dtype=float).reshape(-1)
+    y_pred = np.asarray(y_pred, dtype=float).reshape(-1)
+    residual = y_true - y_pred
+    mse = float(np.mean(residual**2))
+    mae = float(np.mean(np.abs(residual)))
+    y_centered = y_true - float(np.mean(y_true))
+    denom = float(np.sum(y_centered**2))
+    r2 = float(1.0 - np.sum(residual**2) / denom) if denom > 0.0 else float("nan")
+    return {
+        "mse": mse,
+        "rmse": float(np.sqrt(mse)),
+        "mae": mae,
+        "r2": r2,
+    }
+
+
+def evaluate_regression_predictions(y_true: Array, y_pred: Array, group: Array) -> Dict[str, object]:
+    y_true = np.asarray(y_true, dtype=float).reshape(-1)
+    y_pred = np.asarray(y_pred, dtype=float).reshape(-1)
+    group = np.asarray(group, dtype=object).reshape(-1)
+    sqerr = squared_error_per_sample(y_true, y_pred)
+    abserr = absolute_error_per_sample(y_true, y_pred)
+
+    overall = compute_regression_metrics(y_true, y_pred)
+
+    group_rows = []
+    group_mses = []
+    group_weights = []
+    for group_name in pd.unique(group):
+        mask = group == group_name
+        metrics = compute_regression_metrics(y_true[mask], y_pred[mask])
+        group_rows.append(
+            {
+                "group": str(group_name),
+                "n": int(np.sum(mask)),
+                "target_mean": float(np.mean(y_true[mask])),
+                **metrics,
+            }
+        )
+        group_mses.append(float(metrics["mse"]))
+        group_weights.append(float(np.mean(mask)))
+    group_df = pd.DataFrame(group_rows).sort_values("group").reset_index(drop=True)
+    group_mses_arr = np.asarray(group_mses, dtype=float)
+    group_weights_arr = np.asarray(group_weights, dtype=float)
+
+    k = max(1, int(np.ceil(0.10 * sqerr.shape[0])))
+    top_sqerr = np.sort(sqerr)[::-1][:k]
+    weighted_group_mean = float(np.sum(group_weights_arr * group_mses_arr)) if group_weights_arr.size else float("nan")
+    weighted_group_var = (
+        float(np.sum(group_weights_arr * (group_mses_arr - weighted_group_mean) ** 2)) if group_weights_arr.size else float("nan")
+    )
+    core_risk = {
+        "worst_group_mse": float(np.max(group_mses_arr)) if group_mses_arr.size else float("nan"),
+        "tail_mse_top_10pct": float(np.mean(top_sqerr)),
+        "group_mse_variance_weighted": weighted_group_var,
+    }
+    return {
+        "overall": overall,
+        "group_metrics": group_df,
+        "core_risk": core_risk,
+    }
+
+
+def make_regression_prediction_frame(
+    *,
+    sample_id: Array,
+    dataset_name: str,
+    split: str,
+    task_type: str,
+    seed: int,
+    family_name: str,
+    model_name: str,
+    group: Array,
+    y_true: Array,
+    y_pred: Array,
+    metadata: Optional[Mapping[str, Array]] = None,
+) -> pd.DataFrame:
+    y_true = np.asarray(y_true, dtype=float).reshape(-1)
+    y_pred = np.asarray(y_pred, dtype=float).reshape(-1)
+    frame = pd.DataFrame(
+        {
+            "dataset_name": dataset_name,
+            "split": split,
+            "task_type": task_type,
+            "seed": int(seed),
+            "family_name": str(family_name),
+            "model_name": model_name,
+            "sample_id": np.asarray(sample_id, dtype=object),
+            "group": np.asarray(group, dtype=object),
+            "y_true": y_true,
+            "y_pred": y_pred,
+            "squared_error_i": squared_error_per_sample(y_true, y_pred),
+            "abs_error_i": absolute_error_per_sample(y_true, y_pred),
+        }
+    )
+    if metadata is not None:
+        for key, value in metadata.items():
+            arr = np.asarray(value)
+            if arr.ndim == 1 and arr.shape[0] == frame.shape[0]:
+                frame[str(key)] = arr
+    return frame
+
+
+def save_prediction_frame(frame: pd.DataFrame, path: Path) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    frame.to_csv(path, index=False)
