+def _format_float_token(value: float) -> str:
+    return f"{float(value):g}".replace("-", "m").replace(".", "p")
+
+
+def _candidate_label(method_name: str, *, ctb_target_mode: str | None = None, ctb_curvature_eps: float | None = None) -> str:
+    if not str(method_name).startswith("ctb_"):
+        return str(method_name)
+    label = str(method_name)
+    if ctb_target_mode is not None:
+        label += f"__mode-{ctb_target_mode}"
+    if ctb_curvature_eps is not None:
+        label += f"__ceps-{_format_float_token(ctb_curvature_eps)}"
+    return label
+
+
+def _expand_method_candidates(
+    methods: List[str],
+    *,
+    ctb_target_modes: List[str],
+    ctb_curvature_eps: List[float],
+) -> List[Tuple[str, str, Dict[str, object]]]:
+    candidates: List[Tuple[str, str, Dict[str, object]]] = []
+    for method in methods:
+        if str(method).startswith("ctb_"):
+            for mode in ctb_target_modes:
+                for curvature_eps in ctb_curvature_eps:
+                    candidates.append(
+                        (
+                            str(method),
+                            _candidate_label(method, ctb_target_mode=str(mode), ctb_curvature_eps=float(curvature_eps)),
+                            {
+                                "ctb_target_mode": str(mode),
+                                "ctb_curvature_eps": float(curvature_eps),
+                            },
+                        )
+                    )
+        else:
+            candidates.append((str(method), str(method), {}))
+    return candidates
+
