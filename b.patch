--- a/sim/ctb_semantics.py
+++ b/sim/ctb_semantics.py
@@ -46,3 +46,30 @@ def ctb_tree_method_aliases(*, depth: int, task_type: str) -> tuple[str, ...]:
         f"ctb_tree_{depth_token}_{task}",
     )
 
+def normalize_ctb_tree_family_sequence(families):
+    normalized = []
+    seen = set()
+    for family in families:
+        family_name = normalize_ctb_tree_family_name(family)
+        if family_name in seen:
+            continue
+        seen.add(family_name)
+        normalized.append(family_name)
+    return normalized
+
+
+def normalize_ctb_tree_method_name(method_name: str) -> str:
+    method = str(method_name).strip().lower()
+    if not method.startswith("ctb_tree_"):
+        return method
+    return f"ctb_{method[len('ctb_tree_') :]}"
+
+
+def canonical_ctb_tree_result_method(
+    method_name: str,
+    *,
+    update_target_mode: str = "legacy",
+    transport_curvature_eps: float = 1e-6,
+) -> str:
+    base = normalize_ctb_tree_method_name(method_name)
+    return f"{base}{ctb_tree_variant_suffix(update_target_mode, transport_curvature_eps)}"
