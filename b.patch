--- sim/grouped_regression_data.py	1970-01-01 00:00:00.000000000 +0000
+++ sim/grouped_regression_data.py	2026-03-14 02:25:54.924789541 +0000
@@ -0,0 +1,259 @@
+from __future__ import annotations
+
+from dataclasses import dataclass
+from typing import Dict, List, Mapping, Optional, Sequence
+
+import numpy as np
+import pandas as pd
+from sklearn.model_selection import train_test_split
+
+from real_regression import load_real_regression_dataset
+from real_regression.schema import (
+    DEFAULT_REAL_REGRESSION_PROCESSED_ROOT,
+    DEFAULT_REAL_REGRESSION_SPLIT_ROOT,
+    DEFAULT_REAL_REGRESSION_DATA_ROOT,
+)
+
+Array = np.ndarray
+
+
+@dataclass(frozen=True)
+class GroupedRegressionSplit:
+    X: Array
+    y: Array
+    group: Array
+    sample_id: Array
+    difficulty_score: Optional[Array]
+    metadata: Dict[str, Array]
+
+
+@dataclass(frozen=True)
+class GroupedRegressionDataset:
+    dataset_name: str
+    train: GroupedRegressionSplit
+    valid: GroupedRegressionSplit
+    test: GroupedRegressionSplit
+    feature_names: List[str]
+    group_names: List[str]
+    metadata: Dict[str, object]
+
+
+def _as_numpy_strings(values: Sequence[object]) -> Array:
+    return np.asarray([str(v) for v in values], dtype=object)
+
+
+def _safe_group_stratify(group: Sequence[object]) -> Optional[Array]:
+    group_arr = _as_numpy_strings(group)
+    counts = pd.Series(group_arr).value_counts(dropna=False)
+    if not counts.empty and int(counts.min()) >= 2 and counts.shape[0] > 1:
+        return group_arr
+    return None
+
+
+def _split_indices(
+    group: Array,
+    valid_size: float,
+    test_size: float,
+    random_state: int,
+) -> tuple[Array, Array, Array]:
+    if valid_size <= 0.0 or test_size <= 0.0 or valid_size + test_size >= 1.0:
+        raise ValueError("valid_size and test_size must be > 0 and sum to < 1")
+
+    indices = np.arange(group.shape[0], dtype=int)
+    train_valid_idx, test_idx = train_test_split(
+        indices,
+        test_size=test_size,
+        random_state=random_state,
+        stratify=_safe_group_stratify(group),
+    )
+    valid_fraction_within_train_valid = valid_size / (1.0 - test_size)
+    train_idx, valid_idx = train_test_split(
+        train_valid_idx,
+        test_size=valid_fraction_within_train_valid,
+        random_state=random_state + 1,
+        stratify=_safe_group_stratify(group[train_valid_idx]),
+    )
+    return np.sort(train_idx), np.sort(valid_idx), np.sort(test_idx)
+
+
+def _slice_metadata(metadata: Mapping[str, Array], index: Array) -> Dict[str, Array]:
+    return {str(key): np.asarray(value)[index] for key, value in metadata.items()}
+
+
+def _slice_optional(array: Optional[Array], index: Array) -> Optional[Array]:
+    if array is None:
+        return None
+    return np.asarray(array)[index]
+
+
+def _make_split(
+    X: Array,
+    y: Array,
+    group: Array,
+    sample_id: Array,
+    index: Array,
+    metadata: Mapping[str, Array],
+    difficulty_score: Optional[Array],
+) -> GroupedRegressionSplit:
+    return GroupedRegressionSplit(
+        X=np.asarray(X[index], dtype=float),
+        y=np.asarray(y[index], dtype=float),
+        group=np.asarray(group[index], dtype=object),
+        sample_id=np.asarray(sample_id[index], dtype=object),
+        difficulty_score=_slice_optional(difficulty_score, index),
+        metadata=_slice_metadata(metadata, index),
+    )
+
+
+def _difficulty_groups_from_train_residuals(X: Array, y: Array) -> Array:
+    X_design = np.column_stack([np.ones(X.shape[0], dtype=float), X])
+    coef, *_ = np.linalg.lstsq(X_design, y, rcond=None)
+    fitted = X_design @ coef
+    residual = np.abs(y - fitted)
+    q1, q2 = np.quantile(residual, [0.60, 0.90])
+    labels = np.full(y.shape[0], "A_easy_majority", dtype=object)
+    labels[residual >= q1] = "B_medium"
+    labels[residual >= q2] = "C_rare_hard"
+    return labels.astype(object)
+
+
+def simulate_grouped_regression(
+    n_samples: int = 12000,
+    n_features: int = 8,
+    group_probs: Sequence[float] = (0.70, 0.25, 0.05),
+    valid_size: float = 0.20,
+    test_size: float = 0.20,
+    random_state: int = 0,
+) -> GroupedRegressionDataset:
+    if n_features < 6:
+        raise ValueError("n_features must be at least 6 for the default grouped simulator")
+    group_probs_arr = np.asarray(group_probs, dtype=float)
+    if group_probs_arr.shape[0] != 3 or not np.isclose(group_probs_arr.sum(), 1.0):
+        raise ValueError("group_probs must contain 3 probabilities summing to 1")
+
+    rng = np.random.default_rng(random_state)
+    group_idx = rng.choice(3, size=n_samples, p=group_probs_arr)
+    X = rng.normal(loc=0.0, scale=1.0, size=(n_samples, n_features))
+
+    X[group_idx == 0, 0] += 0.8
+    X[group_idx == 0, 1] -= 0.5
+    X[group_idx == 1, 2] += 0.6
+    X[group_idx == 2, 0] *= 1.3
+    X[group_idx == 2, 1] *= 1.2
+
+    f = np.zeros(n_samples, dtype=float)
+    noise_scale = np.zeros(n_samples, dtype=float)
+
+    mask_a = group_idx == 0
+    xa = X[mask_a]
+    f[mask_a] = 1.6 * xa[:, 0] - 1.1 * xa[:, 1] + 0.5 * xa[:, 2] - 0.25
+    noise_scale[mask_a] = 0.45
+
+    mask_b = group_idx == 1
+    xb = X[mask_b]
+    f[mask_b] = 0.9 * np.sin(1.5 * xb[:, 0]) + 0.8 * xb[:, 1] * xb[:, 2] - 0.4 * np.abs(xb[:, 3])
+    noise_scale[mask_b] = 0.75
+
+    mask_c = group_idx == 2
+    xc = X[mask_c]
+    radial = np.sqrt(xc[:, 0] ** 2 + xc[:, 1] ** 2)
+    f[mask_c] = 1.0 * np.sin(2.0 * radial) + 0.9 * xc[:, 2] * xc[:, 3] + 0.35 * (xc[:, 4] ** 2)
+    noise_scale[mask_c] = 1.10
+
+    y = f + rng.normal(loc=0.0, scale=noise_scale, size=n_samples)
+    group = np.asarray(["A_easy_majority", "B_medium", "C_rare_hard"], dtype=object)[group_idx]
+    difficulty_score = np.abs(y - f)
+    sample_id = np.asarray([f"obs_{i}" for i in range(n_samples)], dtype=object)
+    metadata = {
+        "group_index": group_idx.astype(int),
+        "f_true": f.astype(float),
+        "noise_scale": noise_scale.astype(float),
+    }
+
+    train_idx, valid_idx, test_idx = _split_indices(group=group, valid_size=valid_size, test_size=test_size, random_state=random_state)
+    return GroupedRegressionDataset(
+        dataset_name="simulated_grouped_regression",
+        train=_make_split(X, y, group, sample_id, train_idx, metadata, difficulty_score),
+        valid=_make_split(X, y, group, sample_id, valid_idx, metadata, difficulty_score),
+        test=_make_split(X, y, group, sample_id, test_idx, metadata, difficulty_score),
+        feature_names=[f"x{j}" for j in range(n_features)],
+        group_names=sorted(pd.unique(group).tolist()),
+        metadata={
+            "random_state": int(random_state),
+            "n_samples": int(n_samples),
+            "n_features": int(n_features),
+        },
+    )
+
+
+def load_real_grouped_regression_dataset(
+    dataset_name: str,
+    repeat_id: int = 0,
+    raw_root: str | None = None,
+    processed_root: str | None = None,
+    split_root: str | None = None,
+) -> GroupedRegressionDataset:
+    base = load_real_regression_dataset(
+        dataset_name=dataset_name,
+        repeat_id=repeat_id,
+        raw_root=DEFAULT_REAL_REGRESSION_DATA_ROOT if raw_root is None else raw_root,
+        processed_root=DEFAULT_REAL_REGRESSION_PROCESSED_ROOT if processed_root is None else processed_root,
+        split_root=DEFAULT_REAL_REGRESSION_SPLIT_ROOT if split_root is None else split_root,
+    )
+    train_group = _difficulty_groups_from_train_residuals(base.train.X, base.train.y)
+
+    def assign_groups(split_X: Array, split_y: Array) -> tuple[Array, Array]:
+        X_design = np.column_stack([np.ones(base.train.X.shape[0], dtype=float), base.train.X])
+        coef, *_ = np.linalg.lstsq(X_design, base.train.y, rcond=None)
+        split_design = np.column_stack([np.ones(split_X.shape[0], dtype=float), split_X])
+        fitted = split_design @ coef
+        difficulty = np.abs(split_y - fitted)
+        train_design = np.column_stack([np.ones(base.train.X.shape[0], dtype=float), base.train.X])
+        train_fitted = train_design @ coef
+        train_resid = np.abs(base.train.y - train_fitted)
+        q1, q2 = np.quantile(train_resid, [0.60, 0.90])
+        labels = np.full(split_y.shape[0], "A_easy_majority", dtype=object)
+        labels[difficulty >= q1] = "B_medium"
+        labels[difficulty >= q2] = "C_rare_hard"
+        return labels.astype(object), difficulty.astype(float)
+
+    train_labels, train_difficulty = assign_groups(base.train.X, base.train.y)
+    valid_labels, valid_difficulty = assign_groups(base.valid.X, base.valid.y)
+    test_labels, test_difficulty = assign_groups(base.test.X, base.test.y)
+
+    def wrap(split, labels: Array, difficulty: Array) -> GroupedRegressionSplit:
+        return GroupedRegressionSplit(
+            X=np.asarray(split.X, dtype=float),
+            y=np.asarray(split.y, dtype=float),
+            group=np.asarray(labels, dtype=object),
+            sample_id=np.asarray(split.sample_id, dtype=object),
+            difficulty_score=np.asarray(difficulty, dtype=float),
+            metadata={k: np.asarray(v) for k, v in split.metadata.items()},
+        )
+
+    return GroupedRegressionDataset(
+        dataset_name=base.dataset_name,
+        train=wrap(base.train, train_labels, train_difficulty),
+        valid=wrap(base.valid, valid_labels, valid_difficulty),
+        test=wrap(base.test, test_labels, test_difficulty),
+        feature_names=list(base.feature_names),
+        group_names=sorted(pd.unique(np.concatenate([train_labels, valid_labels, test_labels])).tolist()),
+        metadata=dict(base.metadata),
+    )
+
+
+def summarize_grouped_regression_dataset(dataset: GroupedRegressionDataset) -> Dict[str, object]:
+    summary: Dict[str, object] = {
+        "dataset_name": dataset.dataset_name,
+        "feature_dim": int(dataset.train.X.shape[1]),
+        "group_names": list(dataset.group_names),
+    }
+    for split_name in ["train", "valid", "test"]:
+        split = getattr(dataset, split_name)
+        summary[f"n_{split_name}"] = int(split.X.shape[0])
+        summary[f"groups_{split_name}"] = (
+            pd.Series(split.group.astype(str)).value_counts(dropna=False).sort_index().to_dict()
+        )
+        summary[f"target_mean_{split_name}"] = float(np.mean(split.y))
+        summary[f"target_std_{split_name}"] = float(np.std(split.y))
+    return summary
