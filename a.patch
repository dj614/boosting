+def _aggregate_summary(summary_df: pd.DataFrame, group_cols: Sequence[str]) -> pd.DataFrame:
+    if summary_df.empty:
+        return pd.DataFrame(columns=list(group_cols))
+    numeric_cols = [col for col in summary_df.select_dtypes(include=[np.number]).columns if col not in set(group_cols)]
+    mean_df = summary_df.groupby(list(group_cols), dropna=False)[numeric_cols].mean().reset_index()
+    se_df = summary_df.groupby(list(group_cols), dropna=False)[numeric_cols].sem().reset_index().rename(columns={c: f"{c}_se" for c in numeric_cols})
+    return mean_df.merge(se_df, on=list(group_cols), how="left")
+
+
+def _family_selected_metrics(summary_df: pd.DataFrame) -> pd.DataFrame:
+    if summary_df.empty:
+        return pd.DataFrame(columns=summary_df.columns)
+    valid_df = summary_df.loc[summary_df["split"] == "valid"].copy()
+    if valid_df.empty:
+        return pd.DataFrame(columns=summary_df.columns)
+    selected_rows = []
+    group_cols = ["task_type", "dataset_name", "seed", "family_name"]
+    for group_key, sub_df in valid_df.groupby(group_cols, dropna=False):
+        task_type = str(sub_df["task_type"].iloc[0])
+        metric_col = _primary_metric_column(task_type)
+        idx = pd.to_numeric(sub_df[metric_col], errors="coerce").idxmin()
+        selected_rows.append(sub_df.loc[idx, group_cols + ["model_name"]].to_dict())
+    selected_df = pd.DataFrame(selected_rows)
+    if selected_df.empty:
+        return pd.DataFrame(columns=summary_df.columns)
+    return summary_df.merge(selected_df, on=["task_type", "dataset_name", "seed", "family_name", "model_name"], how="inner")
+
+
+def _family_selected_group_metrics(group_df: pd.DataFrame, selected_summary_df: pd.DataFrame) -> pd.DataFrame:
+    if group_df.empty or selected_summary_df.empty:
+        return pd.DataFrame(columns=group_df.columns)
+    keys = selected_summary_df[["task_type", "dataset_name", "seed", "family_name", "model_name", "split"]].drop_duplicates()
+    return group_df.merge(keys, on=["task_type", "dataset_name", "seed", "family_name", "model_name", "split"], how="inner")
