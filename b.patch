+from __future__ import annotations
+
+from typing import Dict
+
+import numpy as np
+
+Array = np.ndarray
+
+
+def _clip_prob(y_prob: Array) -> Array:
+    return np.clip(np.asarray(y_prob, dtype=float).reshape(-1), 1e-8, 1.0 - 1e-8)
+
+
+def classification_metrics(y_true: Array, y_prob: Array) -> Dict[str, float]:
+    y_true = np.asarray(y_true, dtype=int).reshape(-1)
+    y_prob = _clip_prob(y_prob)
+    y_pred = (y_prob >= 0.5).astype(int)
+    log_loss = float(-np.mean(y_true * np.log(y_prob) + (1 - y_true) * np.log(1 - y_prob)))
+    brier = float(np.mean((y_prob - y_true) ** 2))
+    accuracy = float(np.mean(y_pred == y_true))
+    return {
+        "log_loss": log_loss,
+        "brier": brier,
+        "accuracy": accuracy,
+        "positive_rate": float(np.mean(y_true)),
+    }
